# Get your free WAQI API token at: https://aqicn.org/data-platform/token/
WAQI_API_TOKEN=your_waqi_token_here

# Generate a secure random string for JWT signing (use a long random value in production)
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_characters
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# CORS origins (comma-separated). Use * for development, restrict in production.
CORS_ORIGINS=*
